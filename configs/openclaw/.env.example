# OpenClaw runtime environment
# Copy to configs/openclaw/.env and fill local secrets there.

OPENCLAW_GATEWAY_TOKEN=demo-token-not-for-production
OPENCLAW_CONFIG_PATH=/home/node/openclaw-config/openclaw.json
OPENCLAW_STATE_DIR=/home/node/.openclaw

# DeepSeek API key. Do not commit a real key.
DEEPSEEK_API_KEY=sk-replace-with-your-new-key

# OpenAI-compatible proxy key for models.providers.proxy.
OPENAI_API_KEY=sk-replace-with-your-openai-compatible-proxy-key

# Optional: required by douyin-insights-openclaw-plugin.
# Get it from the hosted Social Media MCP provider if you want Douyin tools.
SOCIAL_MEDIA_MCP_API_KEY=

# QQ Mail IMAP/SMTP. Use the QQ Mail authorization code, not your QQ password.
QQ_EMAIL_ADDRESS=your-qq-number@qq.com
QQ_EMAIL_AUTH_CODE=replace-with-qq-mail-authorization-code
