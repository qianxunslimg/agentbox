# Docker Compose 环境变量
# 复制为 .env 使用: cp .env.example .env

# Open WebUI 配置
WEBUI_HOST=127.0.0.1
WEBUI_PORT=3000
WEBUI_AUTH=false
WEBUI_NAME=Local Agent

# LocalAGI 配置
LOCALAGI_HOST=127.0.0.1
LOCALAGI_PORT=8080
LOCALAGI_MODEL=qwen2.5-coder:7b
LOCALAGI_TIMEOUT=5m

# OpenAgentd 配置
OPENAGENTD_HOST=127.0.0.1
OPENAGENTD_PORT=4082

# Ollama 配置（仅在容器内使用）
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_KEEP_ALIVE=24h
